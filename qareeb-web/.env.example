# ------------------------------------------------------------------
# قريب (Qareeb) — متغيّرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية.
#   cp .env.example .env
# كل المتغيّرات تبدأ بـ VITE_ حتى تكون متاحة في المتصفح.
# ------------------------------------------------------------------

# Supabase — من لوحة تحكم المشروع (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps API key
# للجهاز (خرائط قوقل الأصلية): فعّل "Maps SDK for Android" على المفتاح.
# متى وُجد هذا المفتاح تُستخدم خرائط قوقل الأصلية على الجهاز تلقائياً.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# للعودة إلى خرائط CARTO (Leaflet) على الجهاز بدل خرائط قوقل الأصلية:
# VITE_USE_NATIVE_MAPS=0

# خادم توجيه المسارات (OSRM) — بديل احتياطي متى لم تُضبط Valhalla. اتركه فارغاً
# لاستخدام الخادم العام المجاني (للاختبار). مثال:
# VITE_OSRM_URL=https://osrm.your-domain.com

# خادم Valhalla الخاص لملاحة الكابتن (المسار + خطوات الاتجاه) — عالية الحجم فتبقى
# مجانية على خادمك بدل فاتورة قوقل. متى ضُبط تُستخدَم Valhalla، وإلا يعود الكود
# تلقائياً إلى OSRM. راجع docs/VALHALLA_SUDAN_SETUP.md. مثال:
# VITE_VALHALLA_URL=https://valhalla.your-domain.com
# (تقدير الأجرة للعميل يمرّ عبر Google Directions لدقّة حركة المرور — نداء واحد
#  لكل حجز فقط، فلا يرفع فاتورة قوقل.)

# Web Push — المفتاح العام (VAPID public key) لإشعارات السائق.
# ولّده مرة واحدة:  npx web-push generate-vapid-keys
# ضع العام هنا، والخاص كسرّ في Edge Function (انظر supabase/NOTIFICATIONS.md).
# اتركه فارغاً لتعطيل الإشعارات (التطبيق يعمل عادياً بدونها).
VITE_VAPID_PUBLIC_KEY=
