{
  "name": "qareeb-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "قريب (Qareeb) — نقل آمن في كل السودان. تطبيق ويب (عميل/سائق/أدمن).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cap:open": "npx cap open android",
    "apk:customer": "cross-env VITE_APP=customer npm run build && npx cap sync android && cd android && ./gradlew assembleCustomerDebug",
    "apk:driver": "cross-env VITE_APP=driver npm run build && npx cap sync android && cd android && ./gradlew assembleDriverDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@react-google-maps/api": "^2.20.3",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.101.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
