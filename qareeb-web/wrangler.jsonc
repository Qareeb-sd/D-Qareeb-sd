{
  // إعداد نشر "قريب" على Cloudflare (Worker يخدم أصولاً ثابتة كـ SPA).
  // البناء: npm run build → مجلد dist، ثم npx wrangler deploy يرفعه.
  "name": "qareeb",
  "compatibility_date": "2024-12-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
